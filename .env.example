# Telegram bot token from @BotFather
BOT_TOKEN=123456789:YOUR_TOKEN_HERE

# Comma-separated Telegram IDs with admin rights
ADMIN_IDS=123456789

# Database (SQLite async)
DATABASE_URL=sqlite+aiosqlite:///bot.db

# Wake-on-LAN defaults
PC_MAC_ADDRESS=AA:BB:CC:DD:EE:FF
PC_IP_ADDRESS=192.168.1.100
PC_BROADCAST_ADDRESS=192.168.1.255

# Optional host credentials
PC_USERNAME=
PC_PASSWORD=
PC_DOMAIN=WORKGROUP

# Dota integration (optional)
DOTA2_STEAM_API_KEY=
DOTA2_ACCOUNT_ID=

# Notifications
NOTIFICATION_INTERVAL=300
NOTIFY_ON_PC_STATUS=true
NOTIFY_ON_DOTA_GAME=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=bot.log
LOG_ROTATION=10MB
LOG_RETENTION=7

# Debug
DEBUG=false
